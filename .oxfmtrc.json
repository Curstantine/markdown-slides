{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"ignorePatterns": [],
	"printWidth": 100,
	"useTabs": true,
	"tabWidth": 4,
	"sortTailwindcss": {
		"stylesheet": "./src/index.css"
	},
	"sortImports": {
		"customGroups": [
			{
				"groupName": "components",
				"elementNamePattern": ["@/components/**"]
			},
			{
				"groupName": "lib",
				"elementNamePattern": ["@/*"]
			}
		],
		"groups": ["external", "components", "lib"],
		"newlinesBetween": true
	}
}
